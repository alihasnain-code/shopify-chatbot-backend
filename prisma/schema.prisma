generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model conversation {
  id        String    @id
  shop      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  message   message[]
  cartId    String?

  @@index([shop], map: "Conversation_shop_idx")
}

model message {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  content        String       @db.LongText
  createdAt      DateTime     @default(now())
  conversation   conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, map: "Message_conversationId_fkey")

  @@index([conversationId], map: "Message_conversationId_idx")
}
