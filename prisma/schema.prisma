generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model aipersonasettings {
  id                 Int      @id @default(autoincrement())
  sessionId          String   @unique(map: "AiPersonaSettings_sessionId_key")
  customInstructions String?  @db.Text
  tone               String   @default("standard")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  session            session  @relation(fields: [sessionId], references: [id], onDelete: Cascade, map: "AiPersonaSettings_sessionId_fkey")
}

model conversation {
  id        String    @id
  shop      String
  createdAt DateTime  @default(now())
  updatedAt DateTime
  cartId    String?
  message   message[]

  @@index([shop], map: "Conversation_shop_idx")
}

model form {
  id            Int             @id @default(autoincrement())
  sessionId     String
  name          String
  status        String          @default("active")
  fields        String          @db.LongText
  version       Int             @default(1)
  position      Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  session       session         @relation(fields: [sessionId], references: [id], onDelete: Cascade, map: "Form_sessionId_fkey")
  formResponses form_response[]

  @@unique([sessionId, name], map: "Form_sessionId_name_key")
  @@index([sessionId], map: "Form_sessionId_idx")
}

model message {
  id             String       @id
  conversationId String
  role           String
  content        String       @db.LongText
  createdAt      DateTime     @default(now())
  conversation   conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, map: "Message_conversationId_fkey")

  @@index([conversationId], map: "Message_conversationId_idx")
}

model policy_chunks {
  id          Int      @id @default(autoincrement())
  shop_domain String   @db.VarChar(255)
  policy_type String   @db.VarChar(100)
  text_chunk  String   @db.Text
  embedding   String   @db.LongText
  created_at  DateTime @default(now())

  @@index([shop_domain, policy_type])
}

model session {
  id                  String             @id
  shop                String
  state               String
  isOnline            Boolean            @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean            @default(false)
  locale              String?
  collaborator        Boolean?           @default(false)
  emailVerified       Boolean?           @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
  aipersonasettings   aipersonasettings?
  form                form[]
  starterquestion     starterquestion[]
  usagesettings       usagesettings?
  userConfigs         user_configs?
  formResponses       form_response[]
  visitorUsages       visitor_usage[]
  orders              order[]
}

model starterquestion {
  id        Int      @id @default(autoincrement())
  sessionId String
  question  String   @db.VarChar(150)
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  session   session  @relation(fields: [sessionId], references: [id], onDelete: Cascade, map: "StarterQuestion_sessionId_fkey")

  @@index([sessionId], map: "StarterQuestion_sessionId_idx")
}

model usagesettings {
  id                         Int      @id @default(autoincrement())
  sessionId                  String   @unique(map: "UsageSettings_sessionId_key")
  maxMessagesPerConversation Int      @default(15)
  maxMessagesPerVisitor      Int      @default(100)
  resetPeriod                String   @default("hour")
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  session                    session  @relation(fields: [sessionId], references: [id], onDelete: Cascade, map: "UsageSettings_sessionId_fkey")
}

enum SyncStatus {
  IN_PROGRESS
  SYNCED
  FAILED
}

model user_configs {
  id             Int        @id @default(autoincrement())
  sessionId      String     @unique(map: "UserConfigs_sessionId_key")
  policiesStatus SyncStatus @default(IN_PROGRESS)
  lastSyncedAt   DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  session        session    @relation(fields: [sessionId], references: [id], onDelete: Cascade, map: "UserConfigs_sessionId_fkey")

  @@index([sessionId], map: "UserConfigs_sessionId_idx")
}

model form_response {
  id        Int      @id @default(autoincrement())
  formId    Int
  sessionId String
  data      String   @db.Text
  createdAt DateTime @default(now())

  form    form    @relation(fields: [formId], references: [id], onDelete: Cascade, map: "FormResponse_formId_fkey")
  session session @relation(fields: [sessionId], references: [id], onDelete: Cascade, map: "FormResponse_sessionId_fkey")
}

model visitor_usage {
  id           Int      @id @default(autoincrement())
  sessionId    String
  ip           String   @db.VarChar(64)
  windowStart  DateTime @default(now())
  messageCount Int      @default(0)
  updatedAt    DateTime @updatedAt

  session session @relation(fields: [sessionId], references: [id], onDelete: Cascade, map: "VisitorUsage_sessionId_fkey")

  @@unique([sessionId, ip], map: "VisitorUsage_sessionId_ip_key")
}

model order {
  id                Int       @id @default(autoincrement())
  sessionId         String
  shopifyOrderId    String    @unique
  orderNumber       Int // e.g. 1002 — from payload.order_number, what the tool matches against
  orderName         String // e.g. "#1002" — from payload.name, what's shown back to the customer
  email             String?
  financialStatus   String?
  fulfillmentStatus String?
  currency          String?
  totalPrice        String?
  lineItems         String    @db.Text // JSON string: [{ title, variantTitle, quantity }]
  shippingCity      String?
  shippingProvince  String?
  shippingCountry   String?
  cancelledAt       DateTime?
  cancelReason      String?
  shopifyCreatedAt  DateTime
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  session      session             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  fulfillments order_fulfillment[]

  @@index([sessionId, orderNumber])
}

model order_fulfillment {
  id                   Int      @id @default(autoincrement())
  shopifyFulfillmentId String   @unique
  orderId              Int
  status               String?
  shipmentStatus       String?
  trackingCompany      String?
  trackingNumber       String?
  trackingUrl          String?
  shopifyCreatedAt     DateTime
  shopifyUpdatedAt     DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  order order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model code_verifier {
  id             String   @id @default(cuid())
  state          String   @unique
  verifier       String
  shop           String
  conversationId String
  createdAt      DateTime @default(now())
}

model customer_access_token {
  id             String    @id @default(cuid())
  shop           String
  conversationId String
  accessToken    String
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([shop, conversationId])
}
